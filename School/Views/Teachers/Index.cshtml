@model IEnumerable<School.Models.Teacher>

@{
    ViewData["Title"] = Localizer["teachers"];
}

<h1>@ViewData["Title"]</h1>

@{
    if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">@Localizer[TempData["SuccessMessage"].ToString()]</div>
    }
}

<p>
    <a asp-action="Create">@Localizer["create_new"]</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Localizer["name"]
            </th>
            <th>
                @Localizer["qual"]
            </th>
            <th>
                @Localizer["photo"]
            </th>
            <th>
                @Localizer["user"]
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) 
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Qualification)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.FotoPath)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.IdentityUser.UserName)
                </td>
                <td>
                    @{
                        /*
                        <a asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.ID">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.ID">Delete</a>
                        */
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
