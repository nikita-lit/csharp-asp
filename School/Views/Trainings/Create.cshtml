@model School.Models.Training

@{
    ViewData["Title"] = Localizer["create"];
}

<h1>@ViewData["Title"]</h1>

<h4>@Localizer["Training"]</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name" class="control-label">@Localizer["name"]</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price" class="control-label">@Localizer["price"]</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="AlgusKuupaev" class="control-label">@Localizer["start_date"]</label>
                <input asp-for="AlgusKuupaev" class="form-control" type="date" />
                <span asp-validation-for="AlgusKuupaev" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LoppKuupaev" class="control-label">@Localizer["end_date"]</label>
                <input asp-for="LoppKuupaev" class="form-control" type="date" />
                <span asp-validation-for="LoppKuupaev" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MaxOsalejaid" class="control-label">@Localizer["max_participants"]</label>
                <input asp-for="MaxOsalejaid" class="form-control" type="number" />
                <span asp-validation-for="MaxOsalejaid" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CourseID" class="control-label">@Localizer["course"]</label>
                <select asp-for="CourseID" asp-items="ViewBag.CourseList" class="form-control">
                    <option value="">@Localizer["select"]</option>
                </select>
                <span asp-validation-for="CourseID" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TeacherID" class="control-label">@Localizer["teacher"]</label>
                <select asp-for="TeacherID" asp-items="ViewBag.TeacherList" class="form-control">
                    <option value="">@Localizer["select"]</option>
                </select>
                <span asp-validation-for="TeacherID" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="@Localizer["add"]" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">@Localizer["back_to_list"]</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}