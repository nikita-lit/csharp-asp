@using System.Globalization

<ul class="navbar-nav">
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle" href="#" id="langDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            @CultureInfo.CurrentUICulture.TextInfo.ToTitleCase(CultureInfo.CurrentUICulture.NativeName)
        </a>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="langDropdown">
            <li>
                <a class="dropdown-item" asp-controller="Home" asp-action="SetLanguage" asp-route-culture="en-GB" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
                    <img src="~/img/flags/gb.svg" asp-append-version="true" class="flag-icon" alt="GB" /> English
                </a>
            </li>
            <li>
                <a class="dropdown-item" asp-controller="Home" asp-action="SetLanguage" asp-route-culture="et-EE" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
                    <img src="~/img/flags/et.svg" asp-append-version="true" class="flag-icon" alt="EE" /> Eesti
                </a>
            </li>
            <li>
                <a class="dropdown-item" asp-controller="Home" asp-action="SetLanguage" asp-route-culture="ru-RU" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)">
                    <img src="~/img/flags/ru.svg" asp-append-version="true" class="flag-icon" alt="RU" /> Русский
                </a>
            </li>
        </ul>
    </li>
</ul>