@model School.Models.NotifyViewModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<School.LanguageResources> Localizer

@{
    ViewData["Title"] = Localizer["notify_all_title"];
}

<h2>@Localizer["notify_all_heading"]</h2>

<partial name="_StatusMessage" />

<form asp-action="Notify" method="post">
    <div class="form-group">
        <label for="studentSelect">@Localizer["select_user"]</label>
        <select id="studentSelect" name="StudentUserId" class="form-control" required>
            <option value="">-- @Localizer["select_user"] --</option>
            @foreach (var s in Model.Students)
            {
                var isSelS = Model.StudentUserId == s.Value;
                if (isSelS)
                {
                    <option value="@s.Value" selected="selected">@s.Text</option>
                }
                else
                {
                    <option value="@s.Value">@s.Text</option>
                }
            }
        </select>
    </div>

    <div class="form-group mt-2">
        <label for="subject">@Localizer["subject"]</label>
        <input id="subject" name="Subject" class="form-control" value="@Model.Subject" />
    </div>

    <div class="form-group mt-2">
        <label for="body">@Localizer["message"]</label>
        <textarea id="body" name="Body" rows="6" class="form-control">@Model.Body</textarea>
    </div>

    <button type="submit" class="btn btn-primary mt-3">@Localizer["send"]</button>
    @Html.AntiForgeryToken()
</form>
