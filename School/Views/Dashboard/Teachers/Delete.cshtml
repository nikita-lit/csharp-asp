@model School.Models.Teacher

@{
    ViewData["Title"] = Localizer["delete"];
}

<h1>@ViewData["Title"]</h1>

<h4>@Localizer["teacher"]</h4>
<hr />

<div class="alert alert-warning">
    @if ((bool?)ViewData["HasTrainings"] == true)
    {
        <p>@Localizer["cannot_delete_has_trainings", ViewData["TrainingsCount"]]</p>
    }
    else
    {
        <p>@Localizer["confirm_delete"]</p>
    }

    <dl class="row">
        <dt class="col-sm-2">@Localizer["name"]</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">@Localizer["qual"]</dt>
        <dd class="col-sm-10">@Model.Qualification</dd>

        <dt class="col-sm-2">@Localizer["user"]</dt>
        <dd class="col-sm-10">@Model.IdentityUserId</dd>
    </dl>

    @if (!((bool?)ViewData["HasTrainings"] == true))
    {
        <form asp-controller="Dashboard" asp-action="DeleteTeacherConfirmed" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">@Localizer["delete"]</button>
            <a asp-controller="Dashboard" asp-action="Teachers" class="btn btn-secondary">@Localizer["cancel"]</a>
        </form>
    }
    else
    {
        <a asp-controller="Dashboard" asp-action="Teachers" class="btn btn-secondary">@Localizer["back_to_list"]</a>
    }
</div>
