@model School.Models.TeacherCoursesViewModel

@{
    ViewData["Title"] = Localizer["teacher_trainings"];
}

<div class="text-center mb-4">
    <h1 class="display-4">@ViewData["Title"]</h1>
</div>

@if (User.IsInRole("Admin"))
{
    <form method="get" asp-action="TeacherCourses" class="d-flex align-items-center gap-4 mb-3">
        <label class="mb-0">@Localizer["select_teacher"]</label>
        <select name="id" asp-items="ViewBag.TeacherList" class="form-control" style="width: auto;"></select>
        <button type="submit" class="btn btn-primary">@Localizer["submit"]</button>
    </form>
}

@if (Model != null)
{
    <h3 class="mb-3">@Model.Teacher?.Name</h3>

    @if (!Model.Trainings.Any())
    {
        <p>@Localizer["no_courses"]</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var t in Model.Trainings)
            {
                Model.TrainingStudents.TryGetValue(t.Id, out var students);

                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            @{
                                var flag = "";
                                var cname = t.Course?.Name ?? string.Empty;
                                var lower = cname.ToLower();
                            }

                            @if (lower.Contains("ingli") || lower.Contains("engl") || lower.Contains("англ") || lower.Contains("анг"))
                            {
                                flag = "gb.svg";
                            }
                            else if (lower.Contains("eston") || lower.Contains("eesti") || lower.Contains("est") )
                            {
                                flag = "et.svg";
                            }
                            else if (lower.Contains("vene") || lower.Contains("rus") || lower.Contains("русск"))
                            {
                                flag = "ru.svg";
                            }

                            <h5 class="card-title">
                                @if (!string.IsNullOrEmpty(flag)) 
                                {
                                    <img src="~/img/flags/@flag" alt="flag" class="me-1 align-text-bottom" style="width:24px;height:18px;object-fit:cover;margin-bottom:3px;" />
                                }
                                @t.Name
                            </h5>
                            <h6 class="card-subtitle mb-2 text-muted">@Localizer["course"]: @(t.Course?.Name ?? "-")</h6>
                            <p class="card-text small">@t.StartDate.ToString("d") - @t.EndDate.ToString("d")</p>

                            <p class="card-text mb-1"><strong>@Localizer["students"]:</strong></p>
                            @if (students != null && students.Any())
                            {
                                <ul class="list-unstyled mb-0">
                                @foreach (var s in students)
                                {
                                    <li>@s.UserName</li>
                                }
                                </ul>
                            }
                            else
                            {
                                <p class="text-muted small mb-0">@Localizer["no_students_in_course"]</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

